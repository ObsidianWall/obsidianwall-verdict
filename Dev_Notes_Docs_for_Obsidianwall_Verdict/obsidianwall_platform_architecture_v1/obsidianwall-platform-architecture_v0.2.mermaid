    subgraph PIP["в‘¤ PROBABILISTIC INTELLIGENCE PLANE  В·  Python  В·  AI Advisory Layer"]
        direction LR
        REC["Recommendation\nEngine"]:::ai
        EXPL["Explainability\nEngine"]:::ai
        POLASST["Policy\nAssistant"]:::ai
        OPT["Optimization\nEngine"]:::ai
        ANOM["Anomaly\nCorrelation"]:::ai
        CTXR["Context\nReasoning"]:::ai

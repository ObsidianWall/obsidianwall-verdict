graph TB
    classDef go fill:#00ADD8,color:#fff,stroke:#005f73,font-weight:bold
    classDef python fill:#3776AB,color:#fff,stroke:#1a4f7a,font-weight:bold
    classDef contract fill:#1e293b,color:#f8fafc,stroke:#334155,font-weight:bold
    classDef storage fill:#064e3b,color:#f0fdf4,stroke:#065f46,font-weight:bold
    classDef future fill:#f1f5f9,color:#94a3b8,stroke:#cbd5e1,stroke-dasharray:6 4
    classDef input fill:#7c3aed,color:#fff,stroke:#5b21b6,font-weight:bold
    classDef ai fill:#b45309,color:#fff,stroke:#78350f,font-weight:bold
    classDef doctrine fill:#7f1d1d,color:#fef2f2,stroke:#991b1b,font-weight:bold

    subgraph INPUTS["в‘  INPUT LAYER"]
        direction LR
        TFP["Terraform Plan JSON"]:::input
        POLF["Policy Files В· YAML / DSL"]:::input
        CITRIG["CI/CD Event Trigger"]:::input
    end

    subgraph CLI_LAYER["в‘Ў CLI & DISPATCH LAYER  В·  Go"]
        direction LR
        BIN["obsidianwall binary"]:::go
        REG["Executable Registry"]:::go
        DISP["Dispatcher"]:::go
        ADAPT["CI/CD Adapters\nGitHub Actions В· GitLab CI В· Azure DevOps В· Jenkins"]:::go
    end

    subgraph EXEC_LAYER["в‘ў EXECUTABLE LAYER  В·  Python"]
        direction LR
        VERDICT["Verdict\nCost Governance\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTerraform Parser\nCost Evaluator\nCost Policy Packs"]:::python
        SEC["Security\nGovernance"]:::future
        COMP["Compliance\nGovernance"]:::future
        IDENT["Identity\nGovernance"]:::future
        ARCHL["Architecture\nGovernance"]:::future
        AIG["AI Governance"]:::future
    end

    subgraph DGP["в‘Ј DETERMINISTIC GOVERNANCE PLANE  В·  Python  В·  Enforcement Authority"]
        direction LR
        subgraph ENGINE["Decision Engine"]
            DE["Deterministic\nDecision Engine"]:::python
            DSL["Policy DSL\nRuntime"]:::python
        end
        subgraph GOVENG["Governance Engine"]
            AE["Audit Engine"]:::python
            OVR["Override\nGovernance"]:::python
            TRACE["Traceability\nEngine"]:::python
        end
        subgraph SCHEMA["Platform Infrastructure"]
